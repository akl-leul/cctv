# Face Manager Web Application - Environment Variables
# Copy this file to .env and update the values for your environment

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=production

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost/face_manager
# For development: sqlite:///face_manager.db

# Redis Configuration (for sessions and caching)
REDIS_URL=redis://localhost:6379/0

# Face Recognition Settings
FACES_DIR=faces
MODEL_PATH=models/face_recognition_model.pkl

# CCTV Settings
MAX_CAMERAS=4
CAMERA_QUALITY=80
CAMERA_FPS=30

# Security Settings
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5

# File Upload Settings
MAX_CONTENT_LENGTH=16777216
UPLOAD_EXTENSIONS=jpg,jpeg,png

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/face_manager.log

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Email Configuration (for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# External Services
OPENAI_API_KEY=your-openai-api-key
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
