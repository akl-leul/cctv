        {
            "name": "Python: Enhanced CCTV",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/enhanced_cctv_detector.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: Build App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/build_app.py",
            "console": "integratedTerminal",
